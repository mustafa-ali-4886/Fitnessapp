# ============================================
# BMI Calculator - Environment Variables
# ============================================

# Gmail Account Email
EMAIL_USER=support.zerofitness@gmail.com

# Gmail App Password (16 characters with spaces)
# Get from: Google Account > Security > App passwords
EMAIL_PASSWORD=mgge jfru uygf umgl

# Server Port (optional)
PORT=3000

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 
# 1. Rename this file from ".env.example" to ".env"
#
# 2. Replace EMAIL_USER with your Gmail address:
#    EMAIL_USER=your-actual-email@gmail.com
#
# 3. Get App Password:
#    - Go to Google Account: https://myaccount.google.com/
#    - Click "Security" (left sidebar)
#    - Enable "2-Step Verification" if not already enabled
#    - Click "App passwords" (scroll down)
#    - Select "Mail" from dropdown
#    - Select "Windows Computer" (or your device)
#    - Click "Generate"
#    - Copy the 16-character password (includes spaces)
#
# 4. Replace EMAIL_PASSWORD with the copied password:
#    EMAIL_PASSWORD=abcd efgh ijkl mnop
#
# 5. Save the file and run: npm install dotenv
#
# 6. In server.js, add at the top:
#    require('dotenv').config();
#
# ============================================
